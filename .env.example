# Copy this file to .env and fill in real values. Expo inlines any variable prefixed
# with EXPO_PUBLIC_ into the JS bundle at build time (see src/constants/googleAuth.ts).
# Leaving these blank is fine — the app runs normally with Google Sign-In disabled.

# Google Cloud OAuth Client IDs (see README > "Google OAuth setup")
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
