# Copy this file to server/.env and fill in real values. All are optional — the
# server runs fine with defaults for local development.

PORT=4000

# Change these for anything beyond local dev/demo use.
JWT_ACCESS_SECRET=tourx-dev-access-secret-change-me
JWT_REFRESH_SECRET=tourx-dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Google Cloud OAuth "Web application" Client ID — must match the audience of the ID
# token your frontend sends to POST /auth/google. See README > "Google OAuth setup".
GOOGLE_CLIENT_ID=

# Cloudinary (free tier) — profile picture uploads. See README > "Cloudinary setup".
# Find these on your Cloudinary dashboard at https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Anthropic API — powers the AI Translator (100+ languages, auto-detected source
# language) via Claude Haiku 4.5. Get a key at https://console.anthropic.com/settings/keys.
# See README > "AI Translator setup". Without this, the Translator returns a clear
# "not configured" message instead of failing silently.
ANTHROPIC_API_KEY=

# Leave unset (or "development") to have /auth endpoints echo OTP codes in their
# response bodies for easy testing without a real inbox. Set to "production" once
# server/lib/email.js is wired to a real email provider.
NODE_ENV=development
